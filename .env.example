# Specter — Variables de entorno
# Copiar a .env y rellenar con tus valores reales

# API Keys
SHODAN_API_KEY=tu_api_key_aqui

# Paths de herramientas (dejar en blanco para usar el PATH del sistema)
NMAP_PATH=nmap
AIRMON_PATH=airmon-ng
AIRCRACK_PATH=aircrack-ng
BETTERCAP_PATH=bettercap
HASHCAT_PATH=hashcat
JOHN_PATH=john
TCPDUMP_PATH=tcpdump

# Interfaces de red
DEFAULT_INTERFACE=eth0
MONITOR_INTERFACE=wlan0
DEFAULT_TIMEOUT=30

# Reportes
REPORT_FORMAT=markdown
OPERATOR_NAME=Tu Nombre
COMPANY_NAME=Tu Empresa

# Logging
LOG_LEVEL=INFO
